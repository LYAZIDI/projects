{
  "version": 2,
  "framework": null,
  "buildCommand": "npm install --prefix backend --include=dev && (cd backend && npm run build) && npm install && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
